# ---- App ----
APP_NAME=Smart University Management System
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Database ----
# For docker-compose the host is the service name "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sums

# ---- JWT / Security ----
# Generate strong secrets, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=change-me-too-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- First Super Admin (seeded by scripts/seed.py) ----
SUPERADMIN_EMAIL=admin@university.edu
SUPERADMIN_PASSWORD=Admin@12345
SUPERADMIN_FULL_NAME=Super Admin

# ---- CORS ----
CORS_ORIGINS=*

# ---- File uploads ----
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=pdf,docx,png,jpg,jpeg
# b2 = Backblaze B2 (default), local = filesystem fallback
STORAGE_BACKEND=b2
PRESIGNED_URL_EXPIRE_SECONDS=3600

# ---- Backblaze B2 (S3-compatible) ----
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004

# ---- Local storage fallback (when STORAGE_BACKEND=local) ----
LOCAL_STORAGE_DIR=uploads

# ---- AI providers (Phase 2) ----
AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
